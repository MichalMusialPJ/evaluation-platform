# --- Langfuse (must match docker-compose LANGFUSE_INIT_* env vars) ---
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-local-public-key-0000000000
LANGFUSE_SECRET_KEY=sk-lf-local-secret-key-0000000000

# --- Ollama (LLM-as-a-Judge) ---
OLLAMA_HOST=http://localhost:11434

# --- Evaluator HF models (override to use smaller/faster variants) ---
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
SENTIMENT_MODEL=cardiffnlp/twitter-xlm-roberta-base-sentiment
NLI_MODEL=MoritzLaurer/mDeBERTa-v3-base-xnli-multilingual-nli-2mil7

# --- Evaluator polling loop ---
# How often to check Langfuse for new traces and score them.
POLL_INTERVAL_SEC=5

# --- LLM-as-a-Judge scoring ---
# When true, evaluator runs judge_politeness and judge_rage_score via Ollama.
# Adds ~2-5s per trace but gives subjective scores with reasoning.
ENABLE_LLM_JUDGE=true
JUDGE_MODEL=llama3.2:3b
